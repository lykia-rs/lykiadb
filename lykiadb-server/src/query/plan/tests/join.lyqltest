@set(run = "plan")
@group join {

    @test two_way_simple {
        EXPLAIN SELECT * FROM books b
            INNER JOIN categories c ON b.category_id = c.id
            WHERE c.name = 'Science';

        @expect output {
            - filter [(c.name IsEqual Str("Science"))]
              - join [type=Inner, (b.category_id IsEqual c.id)]
                - scan [books as b]
                - scan [categories as c]
        }
    }

    @test three_way_simple {
        EXPLAIN SELECT * FROM books b
            INNER JOIN categories c ON b.category_id = c.id
            INNER JOIN publishers AS p ON b.publisher_id = p.id
            WHERE p.name = 'Springer';

        @expect output {
            - filter [(p.name IsEqual Str("Springer"))]
              - join [type=Inner, (b.publisher_id IsEqual p.id)]
                - join [type=Inner, (b.category_id IsEqual c.id)]
                  - scan [books as b]
                  - scan [categories as c]
                - scan [publishers as p]
        }
    }

    @test three_way_reordered {
        EXPLAIN SELECT * FROM books b
            INNER JOIN
            (
              categories c
              INNER JOIN
              publishers AS p
              ON b.category_id = c.id
            )
            ON b.publisher_id = p.id
            WHERE p.name = 'Springer';

        @expect output {
            - filter [(p.name IsEqual Str("Springer"))]
              - join [type=Inner, (b.publisher_id IsEqual p.id)]
                - scan [books as b]
                - join [type=Inner, (b.category_id IsEqual c.id)]
                  - scan [categories as c]
                  - scan [publishers as p]
        }
    }

    @test eval_scan_join_truthy_condition {
        EXPLAIN SELECT c * e as m FROM
            (
              [1, 2, 3] AS c
              INNER JOIN
              [10, 100, 1000] AS e
              ON 1 = 1
            );

        @expect output {
            - project [(c Multiply e) as m]
              - join [type=Inner, (Num(1.0) IsEqual Num(1.0))]
                - eval_scan [Array(Num(1.0), Num(2.0), Num(3.0))]
                - eval_scan [Array(Num(10.0), Num(100.0), Num(1000.0))]
        }
    }

    @test eval_scan_join_true {
        EXPLAIN SELECT c * e as m FROM
            (
              [1, 2, 3] AS c
              INNER JOIN
              [10, 100, 1000] AS e
              ON true
            );

        @expect output {
            - project [(c Multiply e) as m]
              - join [type=Inner, true]
                - eval_scan [Array(Num(1.0), Num(2.0), Num(3.0))]
                - eval_scan [Array(Num(10.0), Num(100.0), Num(1000.0))]
        }
    }

    @test eval_scan_cross_join {
        EXPLAIN SELECT c * e as m FROM
            (
              [1, 2, 3] AS c
              CROSS JOIN
              [10, 100, 1000] AS e
            );

        @expect output {
            - project [(c Multiply e) as m]
              - join [type=Cross, None]
                - eval_scan [Array(Num(1.0), Num(2.0), Num(3.0))]
                - eval_scan [Array(Num(10.0), Num(100.0), Num(1000.0))]
        }
    }

    @test eval_scan_join_falsy_condition {
        EXPLAIN SELECT c * e as m FROM
            (
              [1, 2, 3] AS c
              INNER JOIN
              [10, 100, 1000] AS e
              ON 1 = 0
            );

        @expect output {
            - project [(c Multiply e) as m]
              - join [type=Inner, (Num(1.0) IsEqual Num(0.0))]
                - eval_scan [Array(Num(1.0), Num(2.0), Num(3.0))]
                - eval_scan [Array(Num(10.0), Num(100.0), Num(1000.0))]
        }
    }

    @test eval_scan_join_false {
        EXPLAIN SELECT c * e as m FROM
            (
              [1, 2, 3] AS c
              INNER JOIN
              [10, 100, 1000] AS e
              ON false
            );

        @expect output {
            - project [(c Multiply e) as m]
              - join [type=Inner, false]
                - eval_scan [Array(Num(1.0), Num(2.0), Num(3.0))]
                - eval_scan [Array(Num(10.0), Num(100.0), Num(1000.0))]
        }
    }

    @test eval_scan_join_condition {
        EXPLAIN SELECT c * e as m FROM
            (
              [1, 2, 3] AS c
              INNER JOIN
              [10, 100, 1000] AS e
              ON c * e > 100
            );

        @expect output {
            - project [(c Multiply e) as m]
              - join [type=Inner, ((c Multiply e) Greater Num(100.0))]
                - eval_scan [Array(Num(1.0), Num(2.0), Num(3.0))]
                - eval_scan [Array(Num(10.0), Num(100.0), Num(1000.0))]
        }
    }
}
