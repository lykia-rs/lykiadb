@group limit_offset {

    @test limit_simple {
        EXPLAIN SELECT * FROM books limit 4 + 4;

        @expect {
            {
              "@type": "limit",
              "count": 8,
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }

    @test limit_with_offset {
        EXPLAIN SELECT * FROM books limit 10 offset 20;

        @expect {
            {
              "@type": "limit",
              "count": 10,
              "source": {
                "@type": "offset",
                "count": 20,
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                }
              }
            }
        }
    }

    @test limit_with_joins {
        EXPLAIN SELECT * FROM books INNER JOIN authors ON books.author_id = authors.id limit 100;

        @expect {
            {
              "@type": "limit",
              "count": 100,
              "source": {
                "@type": "join",
                "join_type": "inner",
                "constraint": "(books.author_id IsEqual authors.id)",
                "left": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                },
                "right": {
                  "@type": "scan",
                  "collection": "authors",
                  "alias": "authors"
                }
              }
            }
        }
    }

    @test limit_compound_and_joins {
        EXPLAIN SELECT * FROM books INNER JOIN authors ON books.author_id = authors.id UNION SELECT * FROM books INNER JOIN authors ON books.author_id = authors.id LIMIT 100;

        @expect {
            {
              "@type": "limit",
              "count": 100,
              "source": {
                "@type": "compound",
                "operator": "union",
                "source": {
                  "@type": "join",
                  "join_type": "inner",
                  "constraint": "(books.author_id IsEqual authors.id)",
                  "left": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  },
                  "right": {
                    "@type": "scan",
                    "collection": "authors",
                    "alias": "authors"
                  }
                },
                "right": {
                  "@type": "join",
                  "join_type": "inner",
                  "constraint": "(books.author_id IsEqual authors.id)",
                  "left": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  },
                  "right": {
                    "@type": "scan",
                    "collection": "authors",
                    "alias": "authors"
                  }
                }
              }
            }
        }
    }
}
