@group limit_offset {

    @test limit_simple {
        EXPLAIN SELECT * FROM books limit 4 + 4;

        @expect {
            {
              "count": 8,
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "limit"
            }
        }
    }

    @test limit_with_offset {
        EXPLAIN SELECT * FROM books limit 10 offset 20;

        @expect {
            {
              "count": 10,
              "source": {
                "count": 20,
                "source": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "type": "offset"
              },
              "type": "limit"
            }
        }
    }

    @test limit_with_joins {
        EXPLAIN SELECT * FROM books INNER JOIN authors ON books.author_id = authors.id limit 100;

        @expect {
            {
              "count": 100,
              "source": {
                "constraint": "(books.author_id IsEqual authors.id)",
                "join_type": "inner",
                "left": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "right": {
                  "alias": "authors",
                  "collection": "authors",
                  "type": "scan"
                },
                "type": "join"
              },
              "type": "limit"
            }
        }
    }

    @test limit_compound_and_joins {
        EXPLAIN SELECT * FROM books INNER JOIN authors ON books.author_id = authors.id UNION SELECT * FROM books INNER JOIN authors ON books.author_id = authors.id LIMIT 100;

        @expect {
            {
              "count": 100,
              "source": {
                "operator": "union",
                "right": {
                  "constraint": "(books.author_id IsEqual authors.id)",
                  "join_type": "inner",
                  "left": {
                    "alias": "books",
                    "collection": "books",
                    "type": "scan"
                  },
                  "right": {
                    "alias": "authors",
                    "collection": "authors",
                    "type": "scan"
                  },
                  "type": "join"
                },
                "source": {
                  "constraint": "(books.author_id IsEqual authors.id)",
                  "join_type": "inner",
                  "left": {
                    "alias": "books",
                    "collection": "books",
                    "type": "scan"
                  },
                  "right": {
                    "alias": "authors",
                    "collection": "authors",
                    "type": "scan"
                  },
                  "type": "join"
                },
                "type": "compound"
              },
              "type": "limit"
            }
        }
    }
}
