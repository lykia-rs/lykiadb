@group filter {

    @test simple {
        EXPLAIN SELECT * FROM books b where title like '%hello%';

        @expect {
            {
              "predicate": "(title Like Str(\"%hello%\"))",
              "source": {
                "alias": "b",
                "collection": "books",
                "type": "scan"
              },
              "type": "filter"
            }
        }
    }

    @test in_array {
        EXPLAIN SELECT * FROM books b where id in [1, 2, 3];

        @expect {
            {
              "predicate": "(id In Array(Num(1.0), Num(2.0), Num(3.0)))",
              "source": {
                "alias": "b",
                "collection": "books",
                "type": "scan"
              },
              "type": "filter"
            }
        }
    }

    @test in_array_via_select {
        EXPLAIN SELECT * FROM books b where id in (select n from [1, 2, 3] as ids);

        @expect {
            {
              "predicate": "(id In (<SqlSelect>))",
              "source": {
                "alias": "b",
                "collection": "books",
                "type": "scan"
              },
              "subqueries": [
                {
                  "fields": [
                    "n"
                  ],
                  "source": {
                    "alias": "ids",
                    "expr": "Array(Num(1.0), Num(2.0), Num(3.0))",
                    "type": "eval_scan"
                  },
                  "type": "projection"
                }
              ],
              "type": "filter"
            }
        }
    }

    @test between {
        EXPLAIN SELECT * FROM books b where id between 1 and 10;

        @expect {
            {
              "predicate": "(id Between Num(1.0) And Num(10.0))",
              "source": {
                "alias": "b",
                "collection": "books",
                "type": "scan"
              },
              "type": "filter"
            }
        }
    }

    @test with_subquery {
        EXPLAIN SELECT * FROM books b where author_id in (SELECT id FROM authors where name = 'John') or publisher_id in (SELECT id FROM publishers where name = 'Elsevier');

        @expect {
            {
              "predicate": "(author_id In (<SqlSelect>)) Or (publisher_id In (<SqlSelect>))",
              "source": {
                "alias": "b",
                "collection": "books",
                "type": "scan"
              },
              "subqueries": [
                {
                  "fields": [
                    "id"
                  ],
                  "source": {
                    "predicate": "(name IsEqual Str(\"John\"))",
                    "source": {
                      "alias": "authors",
                      "collection": "authors",
                      "type": "scan"
                    },
                    "type": "filter"
                  },
                  "type": "projection"
                },
                {
                  "fields": [
                    "id"
                  ],
                  "source": {
                    "predicate": "(name IsEqual Str(\"Elsevier\"))",
                    "source": {
                      "alias": "publishers",
                      "collection": "publishers",
                      "type": "scan"
                    },
                    "type": "filter"
                  },
                  "type": "projection"
                }
              ],
              "type": "filter"
            }
        }
    }
}
