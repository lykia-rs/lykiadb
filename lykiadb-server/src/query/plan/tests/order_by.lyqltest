@group order_by {

    @test simple {
        EXPLAIN SELECT * FROM books b order by title;

        @expect {
            {
              "@type": "order",
              "key": [
                [
                  "title",
                  "asc"
                ]
              ],
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "b"
              }
            }
        }
    }

    @test multiple {
        EXPLAIN SELECT * FROM books b order by title, id desc;

        @expect {
            {
              "@type": "order",
              "key": [
                [
                  "title",
                  "asc"
                ],
                [
                  "id",
                  "desc"
                ]
              ],
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "b"
              }
            }
        }
    }

    @test compound {
        EXPLAIN SELECT * FROM books UNION SELECT * FROM books order by title, id desc;

        @expect {
            {
              "@type": "order",
              "key": [
                [
                  "title",
                  "asc"
                ],
                [
                  "id",
                  "desc"
                ]
              ],
              "source": {
                "@type": "compound",
                "operator": "union",
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                },
                "right": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                }
              }
            }
        }
    }
}
