@set(run = "plan")
@group order_by {

    @test simple {
        EXPLAIN SELECT * FROM books b order by title;

        @expect output {
            - order [(title, Asc)]
              - scan [books as b]
        }
    }

    @test multiple {
        EXPLAIN SELECT * FROM books b order by title, id desc;

        @expect output {
            - order [(title, Asc), (id, Desc)]
              - scan [books as b]
        }
    }

    @test compound {
        EXPLAIN SELECT * FROM books UNION SELECT * FROM books order by title, id desc;

        @expect output {
            - order [(title, Asc), (id, Desc)]
              - compound [type=Union]
                - scan [books as books]
                - scan [books as books]
        }
    }
}
