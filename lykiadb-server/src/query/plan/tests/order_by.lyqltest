@group order_by {

    @test simple {
        EXPLAIN SELECT * FROM books b order by title;

        @expect {
            {
              "key": [
                [
                  "title",
                  "asc"
                ]
              ],
              "source": {
                "alias": "b",
                "collection": "books",
                "type": "scan"
              },
              "type": "order"
            }
        }
    }

    @test multiple {
        EXPLAIN SELECT * FROM books b order by title, id desc;

        @expect {
            {
              "key": [
                [
                  "title",
                  "asc"
                ],
                [
                  "id",
                  "desc"
                ]
              ],
              "source": {
                "alias": "b",
                "collection": "books",
                "type": "scan"
              },
              "type": "order"
            }
        }
    }

    @test compound {
        EXPLAIN SELECT * FROM books UNION SELECT * FROM books order by title, id desc;

        @expect {
            {
              "key": [
                [
                  "title",
                  "asc"
                ],
                [
                  "id",
                  "desc"
                ]
              ],
              "source": {
                "operator": "union",
                "right": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "source": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "type": "compound"
              },
              "type": "order"
            }
        }
    }
}
