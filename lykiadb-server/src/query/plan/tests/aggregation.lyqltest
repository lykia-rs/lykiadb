@group aggregation {

    @test single {
        EXPLAIN SELECT id FROM books b GROUP BY id;

        @expect {
            - project [id as id]
              - aggregate [group_by=[id], aggregates=[]]
                - scan [books as b]
        }
    }

    @test multiple {
        EXPLAIN SELECT release_year AS yr FROM books b GROUP BY release_year, publisher_id;

        @expect {
            - project [release_year as yr]
              - aggregate [group_by=[release_year, publisher_id], aggregates=[]]
                - scan [books as b]
        }
    }

    @test with_1_aggregate {
        EXPLAIN SELECT publisher_id, release_year AS yr, avg(rating) AS avg_rating, avg(rating) AS avg_rating_dup FROM books b GROUP BY release_year, publisher_id ORDER BY yr;

        @expect {
            - order [(yr, Asc)]
              - project [publisher_id as publisher_id, release_year as yr, avg(rating) as avg_rating, avg(rating) as avg_rating_dup]
                - aggregate [group_by=[release_year, publisher_id], aggregates=[avg(rating)]]
                  - scan [books as b]
        }
    }

    @test with_2_aggregates {
        EXPLAIN SELECT publisher_id, release_year AS yr, avg(rating) AS avg_rating, avg(rating + 1) AS avg_rating_plus FROM books b GROUP BY release_year, publisher_id ORDER BY yr;

        @expect {
            - order [(yr, Asc)]
              - project [publisher_id as publisher_id, release_year as yr, avg(rating) as avg_rating, avg((rating Add Num(1.0))) as avg_rating_plus]
                - aggregate [group_by=[release_year, publisher_id], aggregates=[avg((rating Add Num(1.0))), avg(rating)]]
                  - scan [books as b]
        }
    }

    @test having {
        EXPLAIN SELECT publisher_id FROM books GROUP BY publisher_id HAVING avg(rating) > 3.0;

        @expect {
            - project [publisher_id as publisher_id]
              - filter [(avg(rating) Greater Num(3.0))]
                - aggregate [group_by=[publisher_id], aggregates=[avg(rating)]]
                  - scan [books as books]
        }
    }

    @test having_without_group_by {
        EXPLAIN SELECT avg(rating) FROM books HAVING avg(rating) > 3.0;

        @expect {
            - project [avg(rating) as avg(rating)]
              - filter [(avg(rating) Greater Num(3.0))]
                - aggregate [group_by=[], aggregates=[avg(rating)]]
                  - scan [books as books]
        }
    }

    @test having_with_regular_value {
        EXPLAIN SELECT avg(rating) FROM books HAVING anything > 10;

        @expect {
            - project [avg(rating) as avg(rating)]
              - filter [(anything Greater Num(10.0))]
                - aggregate [group_by=[], aggregates=[avg(rating)]]
                  - scan [books as books]
        }
    }

    @test aggregations_with_regular_functions {
        EXPLAIN SELECT avg(rating), capitalize("id=" + id) as id_label FROM books group by id;

        @expect {
            - project [avg(rating) as avg(rating), capitalize((Str("id=") Add id)) as id_label]
              - aggregate [group_by=[id], aggregates=[avg(rating)]]
                - scan [books as books]
        }
    }
}
