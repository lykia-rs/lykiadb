@group aggregation {

    @test single {
        EXPLAIN SELECT id FROM books b GROUP BY id;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "id"
              ],
              "source": {
                "@type": "aggregate",
                "group_by": [
                  "id"
                ],
                "aggregates": [],
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "b"
                }
              }
            }
        }
    }

    @test multiple {
        EXPLAIN SELECT release_year AS yr FROM books b GROUP BY release_year, publisher_id;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "release_year as yr"
              ],
              "source": {
                "@type": "aggregate",
                "group_by": [
                  "release_year",
                  "publisher_id"
                ],
                "aggregates": [],
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "b"
                }
              }
            }
        }
    }

    @test with_1_aggregate {
        EXPLAIN SELECT publisher_id, release_year AS yr, avg(rating) AS avg_rating, avg(rating) AS avg_rating_dup FROM books b GROUP BY release_year, publisher_id ORDER BY yr;

        @expect {
            {
              "@type": "order",
              "key": [
                [
                  "yr",
                  "asc"
                ]
              ],
              "source": {
                "@type": "projection",
                "fields": [
                  "publisher_id",
                  "release_year as yr",
                  "avg(rating) as avg_rating",
                  "avg(rating) as avg_rating_dup"
                ],
                "source": {
                  "@type": "aggregate",
                  "group_by": [
                    "release_year",
                    "publisher_id"
                  ],
                  "aggregates": [
                    "avg(rating)"
                  ],
                  "source": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "b"
                  }
                }
              }
            }
        }
    }

    @test with_2_aggregates {
        EXPLAIN SELECT publisher_id, release_year AS yr, avg(rating) AS avg_rating, avg(rating + 1) AS avg_rating_plus FROM books b GROUP BY release_year, publisher_id ORDER BY yr;

        @expect {
            {
              "@type": "order",
              "key": [
                [
                  "yr",
                  "asc"
                ]
              ],
              "source": {
                "@type": "projection",
                "fields": [
                  "publisher_id",
                  "release_year as yr",
                  "avg(rating) as avg_rating",
                  "avg((rating Add Num(1.0))) as avg_rating_plus"
                ],
                "source": {
                  "@type": "aggregate",
                  "group_by": [
                    "release_year",
                    "publisher_id"
                  ],
                  "aggregates": [
                    "avg((rating Add Num(1.0)))",
                    "avg(rating)"
                  ],
                  "source": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "b"
                  }
                }
              }
            }
        }
    }

    @test having {
        EXPLAIN SELECT publisher_id FROM books GROUP BY publisher_id HAVING avg(rating) > 3.0;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "publisher_id"
              ],
              "source": {
                "@type": "filter",
                "predicate": "(avg(rating) Greater Num(3.0))",
                "source": {
                  "@type": "aggregate",
                  "group_by": [
                    "publisher_id"
                  ],
                  "aggregates": [
                    "avg(rating)"
                  ],
                  "source": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  }
                }
              }
            }
        }
    }

    @test having_without_group_by {
        EXPLAIN SELECT avg(rating) FROM books HAVING avg(rating) > 3.0;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "avg(rating)"
              ],
              "source": {
                "@type": "filter",
                "predicate": "(avg(rating) Greater Num(3.0))",
                "source": {
                  "@type": "aggregate",
                  "group_by": [],
                  "aggregates": [
                    "avg(rating)"
                  ],
                  "source": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  }
                }
              }
            }
        }
    }

    @test having_with_regular_value {
        EXPLAIN SELECT avg(rating) FROM books HAVING anything > 10;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "avg(rating)"
              ],
              "source": {
                "@type": "filter",
                "predicate": "(anything Greater Num(10.0))",
                "source": {
                  "@type": "aggregate",
                  "group_by": [],
                  "aggregates": [
                    "avg(rating)"
                  ],
                  "source": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  }
                }
              }
            }
        }
    }

    @test aggregations_with_regular_functions {
        EXPLAIN SELECT avg(rating), capitalize("id=" + id) as id_label FROM books group by id;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "avg(rating)",
                "capitalize((Str(\"id=\") Add id)) as id_label"
              ],
              "source": {
                "@type": "aggregate",
                "group_by": [
                  "id"
                ],
                "aggregates": [
                  "avg(rating)"
                ],
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                }
              }
            }
        }
    }
}
