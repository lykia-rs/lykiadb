@group from {

    @test plain {
        EXPLAIN SELECT * FROM books;

        @expect {
            {
              "alias": "books",
              "collection": "books",
              "type": "scan"
            }
        }
    }

    @test expression {
        EXPLAIN SELECT * FROM [1,1,2,3,5,8,13] as fib;

        @expect {
            {
              "alias": "fib",
              "expr": "Array(Num(1.0), Num(1.0), Num(2.0), Num(3.0), Num(5.0), Num(8.0), Num(13.0))",
              "type": "eval_scan"
            }
        }
    }

    @test subquery {
        EXPLAIN SELECT u.id as id FROM (select * from books) u;

        @expect {
            {
              "fields": [
                "u.id as id"
              ],
              "source": {
                "alias": "u",
                "source": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "type": "subquery"
              },
              "type": "projection"
            }
        }
    }

    @test mixed {
        EXPLAIN SELECT * FROM books, [1,2,3] as num;

        @expect {
            {
              "constraint": null,
              "join_type": "cross",
              "left": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "right": {
                "alias": "num",
                "expr": "Array(Num(1.0), Num(2.0), Num(3.0))",
                "type": "eval_scan"
              },
              "type": "join"
            }
        }
    }
}
