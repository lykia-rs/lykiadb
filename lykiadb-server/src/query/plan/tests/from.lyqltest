@group from {

    @test plain {
        EXPLAIN SELECT * FROM books;

        @expect {
            {
              "@type": "scan",
              "collection": "books",
              "alias": "books"
            }
        }
    }

    @test expression {
        EXPLAIN SELECT * FROM [1,1,2,3,5,8,13] as fib;

        @expect {
            {
              "@type": "eval_scan",
              "expr": "Array(Num(1.0), Num(1.0), Num(2.0), Num(3.0), Num(5.0), Num(8.0), Num(13.0))",
              "alias": "fib"
            }
        }
    }

    @test subquery {
        EXPLAIN SELECT u.id as id FROM (select * from books) u;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "u.id as id"
              ],
              "source": {
                "@type": "subquery",
                "alias": "u",
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                }
              }
            }
        }
    }

    @test mixed {
        EXPLAIN SELECT * FROM books, [1,2,3] as num;

        @expect {
            {
              "@type": "join",
              "join_type": "cross",
              "constraint": null,
              "left": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              },
              "right": {
                "@type": "eval_scan",
                "expr": "Array(Num(1.0), Num(2.0), Num(3.0))",
                "alias": "num"
              }
            }
        }
    }
}
