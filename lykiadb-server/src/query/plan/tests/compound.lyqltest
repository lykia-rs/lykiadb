@set(run = "plan")
@group compound {

    @test simple_union {
        EXPLAIN SELECT * FROM books
        UNION
        SELECT * FROM books;

        @expect output {
            - compound [type=Union]
              - scan [books as books]
              - scan [books as books]
        }
    }

    @test simple_intersect {
        EXPLAIN SELECT * FROM books
        INTERSECT
        SELECT * FROM books;

        @expect output {
            - compound [type=Intersect]
              - scan [books as books]
              - scan [books as books]
        }
    }

    @test simple_except {
        EXPLAIN SELECT * FROM books
        EXCEPT
        SELECT * FROM books;

        @expect output {
            - compound [type=Except]
              - scan [books as books]
              - scan [books as books]
        }
    }

    @test nested {
        EXPLAIN SELECT * FROM books where id > 5
        UNION
        SELECT * FROM books
        INTERSECT
        SELECT * FROM books
        EXCEPT
        SELECT * FROM books;

        @expect output {
            - compound [type=Union]
              - filter [(id Greater Num(5.0))]
                - scan [books as books]
              - compound [type=Intersect]
                - scan [books as books]
                - compound [type=Except]
                  - scan [books as books]
                  - scan [books as books]
        }
    }

    @test with_projection {
        EXPLAIN SELECT id FROM books where id > 5
        UNION
        SELECT title FROM books;

        @expect output {
            - compound [type=Union]
              - project [id as id]
                - filter [(id Greater Num(5.0))]
                  - scan [books as books]
              - project [title as title]
                - scan [books as books]
        }
    }
}
