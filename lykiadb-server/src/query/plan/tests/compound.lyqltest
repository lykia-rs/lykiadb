@group compound {

    @test simple_union {
        EXPLAIN SELECT * FROM books UNION SELECT * FROM books;

        @expect {
            {
              "@type": "compound",
              "operator": "union",
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              },
              "right": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }

    @test simple_intersect {
        EXPLAIN SELECT * FROM books INTERSECT SELECT * FROM books;

        @expect {
            {
              "@type": "compound",
              "operator": "intersect",
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              },
              "right": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }

    @test simple_except {
        EXPLAIN SELECT * FROM books EXCEPT SELECT * FROM books;

        @expect {
            {
              "@type": "compound",
              "operator": "except",
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              },
              "right": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }

    @test nested {
        EXPLAIN SELECT * FROM books where id > 5 UNION SELECT * FROM books INTERSECT SELECT * FROM books EXCEPT SELECT * FROM books;

        @expect {
            {
              "@type": "compound",
              "operator": "union",
              "source": {
                "@type": "filter",
                "predicate": "(id Greater Num(5.0))",
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                }
              },
              "right": {
                "@type": "compound",
                "operator": "intersect",
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                },
                "right": {
                  "@type": "compound",
                  "operator": "except",
                  "source": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  },
                  "right": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  }
                }
              }
            }
        }
    }

    @test with_projection {
        EXPLAIN SELECT id FROM books where id > 5 UNION SELECT title FROM books;

        @expect {
            {
              "@type": "compound",
              "operator": "union",
              "source": {
                "@type": "projection",
                "fields": [
                  "id"
                ],
                "source": {
                  "@type": "filter",
                  "predicate": "(id Greater Num(5.0))",
                  "source": {
                    "@type": "scan",
                    "collection": "books",
                    "alias": "books"
                  }
                }
              },
              "right": {
                "@type": "projection",
                "fields": [
                  "title"
                ],
                "source": {
                  "@type": "scan",
                  "collection": "books",
                  "alias": "books"
                }
              }
            }
        }
    }
}
