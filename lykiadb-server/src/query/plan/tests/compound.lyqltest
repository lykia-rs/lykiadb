@group compound {

    @test simple_union {
        EXPLAIN SELECT * FROM books UNION SELECT * FROM books;

        @expect {
            {
              "operator": "union",
              "right": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "compound"
            }
        }
    }

    @test simple_intersect {
        EXPLAIN SELECT * FROM books INTERSECT SELECT * FROM books;

        @expect {
            {
              "operator": "intersect",
              "right": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "compound"
            }
        }
    }

    @test simple_except {
        EXPLAIN SELECT * FROM books EXCEPT SELECT * FROM books;

        @expect {
            {
              "operator": "except",
              "right": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "compound"
            }
        }
    }

    @test nested {
        EXPLAIN SELECT * FROM books where id > 5 UNION SELECT * FROM books INTERSECT SELECT * FROM books EXCEPT SELECT * FROM books;

        @expect {
            {
              "operator": "union",
              "right": {
                "operator": "intersect",
                "right": {
                  "operator": "except",
                  "right": {
                    "alias": "books",
                    "collection": "books",
                    "type": "scan"
                  },
                  "source": {
                    "alias": "books",
                    "collection": "books",
                    "type": "scan"
                  },
                  "type": "compound"
                },
                "source": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "type": "compound"
              },
              "source": {
                "predicate": "(id Greater Num(5.0))",
                "source": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "type": "filter"
              },
              "type": "compound"
            }
        }
    }

    @test with_projection {
        EXPLAIN SELECT id FROM books where id > 5 UNION SELECT title FROM books;

        @expect {
            {
              "operator": "union",
              "right": {
                "fields": [
                  "title"
                ],
                "source": {
                  "alias": "books",
                  "collection": "books",
                  "type": "scan"
                },
                "type": "projection"
              },
              "source": {
                "fields": [
                  "id"
                ],
                "source": {
                  "predicate": "(id Greater Num(5.0))",
                  "source": {
                    "alias": "books",
                    "collection": "books",
                    "type": "scan"
                  },
                  "type": "filter"
                },
                "type": "projection"
              },
              "type": "compound"
            }
        }
    }
}
