@group projection {

    @test implicit_all {
        EXPLAIN SELECT * FROM books;

        @expect {
            - scan [books as books]
        }
    }

    @test explicit_all {
        EXPLAIN SELECT books.* FROM books;

        @expect {
            - project [* in books]
              - scan [books as books]
        }
    }

    @test simple {
        EXPLAIN SELECT id, title FROM books;

        @expect {
            - project [id as id, title as title]
              - scan [books as books]
        }
    }

    @test constants {
        EXPLAIN SELECT 5 + 5 as ten FROM books;

        @expect {
            - project [(Num(5.0) Add Num(5.0)) as ten]
              - scan [books as books]
        }
    }

    @test function_call {
        EXPLAIN SELECT capitalize("str") as json_str_title FROM books;

        @expect {
            - project [capitalize(Str("str")) as json_str_title]
              - scan [books as books]
        }
    }
}
