@group projection {

    @test implicit_all {
        EXPLAIN SELECT * FROM books;

        @expect {
            {
              "alias": "books",
              "collection": "books",
              "type": "scan"
            }
        }
    }

    @test explicit_all {
        EXPLAIN SELECT books.* FROM books;

        @expect {
            {
              "fields": [
                "books.*"
              ],
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "projection"
            }
        }
    }

    @test simple {
        EXPLAIN SELECT id, title FROM books;

        @expect {
            {
              "fields": [
                "id",
                "title"
              ],
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "projection"
            }
        }
    }

    @test constants {
        EXPLAIN SELECT 5 + 5 as ten FROM books;

        @expect {
            {
              "fields": [
                "(Num(5.0) Add Num(5.0)) as ten"
              ],
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "projection"
            }
        }
    }

    @test function_call {
        EXPLAIN SELECT capitalize("str") as json_str_title FROM books;

        @expect {
            {
              "fields": [
                "capitalize(Str(\"str\")) as json_str_title"
              ],
              "source": {
                "alias": "books",
                "collection": "books",
                "type": "scan"
              },
              "type": "projection"
            }
        }
    }
}
