@group projection {

    @test implicit_all {
        EXPLAIN SELECT * FROM books;

        @expect {
            {
              "@type": "scan",
              "collection": "books",
              "alias": "books"
            }
        }
    }

    @test explicit_all {
        EXPLAIN SELECT books.* FROM books;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "books.*"
              ],
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }

    @test simple {
        EXPLAIN SELECT id, title FROM books;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "id",
                "title"
              ],
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }

    @test constants {
        EXPLAIN SELECT 5 + 5 as ten FROM books;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "(Num(5.0) Add Num(5.0)) as ten"
              ],
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }

    @test function_call {
        EXPLAIN SELECT capitalize("str") as json_str_title FROM books;

        @expect {
            {
              "@type": "projection",
              "fields": [
                "capitalize(Str(\"str\")) as json_str_title"
              ],
              "source": {
                "@type": "scan",
                "collection": "books",
                "alias": "books"
              }
            }
        }
    }
}
