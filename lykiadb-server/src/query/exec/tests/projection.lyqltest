@group projection {

    @test multiply {
        select item * 2 as doubled from [1, 2, 3] as item;

        @expect {
            [
              {
                "doubled": 2.0
              },
              {
                "doubled": 4.0
              },
              {
                "doubled": 6.0
              }
            ]
        }
    }

    @test add_constant {
        select item + 10 as shifted from [1, 2, 3] as item;

        @expect {
            [
              {
                "shifted": 11.0
              },
              {
                "shifted": 12.0
              },
              {
                "shifted": 13.0
              }
            ]
        }
    }

    @test rename {
        select item as value from [10, 20, 30] as item;

        @expect {
            [
              {
                "value": 10.0
              },
              {
                "value": 20.0
              },
              {
                "value": 30.0
              }
            ]
        }
    }

    @test constant_expr {
        select 5 + 5 as ten from [1] as item;

        @expect {
            [
              {
                "ten": 10.0
              }
            ]
        }
    }

    @test multiple_fields {
        select item as original, item * item as squared from [1, 2, 3, 4] as item;

        @expect {
            [
              {
                "original": 1.0,
                "squared": 1.0
              },
              {
                "original": 2.0,
                "squared": 4.0
              },
              {
                "original": 3.0,
                "squared": 9.0
              },
              {
                "original": 4.0,
                "squared": 16.0
              }
            ]
        }
    }
}
