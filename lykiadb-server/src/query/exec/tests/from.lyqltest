@set(run = "interpreter")
@group from {

    @test simple_array {
        out::print(select item from [1, 2, 3] as item);

        @expect output {
            [{item: 1}, {item: 2}, {item: 3}]
        }
    }

    @test single_element {
        out::print(select x from [42] as x);

        @expect output {
            [{x: 42}]
        }
    }

    @test empty_array {
        out::print(select item from [] as item);

        @expect output {
            []
        }
    }

    @test select_all_fields {
        out::print(select * from [1, 2, 3] as nums);

        @expect output {
            [{nums: 1}, {nums: 2}, {nums: 3}]
        }
    }

    @test subquery {
        out::print(select u.item from (select item from [1, 2, 3] as item) u);

        @expect output {
            [{u.item: 1}, {u.item: 2}, {u.item: 3}]
        }
    }
}
