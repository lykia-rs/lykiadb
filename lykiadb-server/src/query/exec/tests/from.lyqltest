@group from {

    @test simple_array {
        out::print(select item from [1, 2, 3] as item);

        @expect output {
          [
            {
              "item": 1.0
            },
            {
              "item": 2.0
            },
            {
              "item": 3.0
            }
          ]
        }
    }

    @test single_element {
        out::print(select x from [42] as x);

        @expect output {
          [
            {
              "x": 42.0
            }
          ]
        }
    }

    @test empty_array {
        out::print(select item from [] as item);

        @expect output {
            []
        }
    }

    @test select_all_fields {
        out::print(select * from [1, 2, 3] as nums);

        @expect output {
          [
            {
              "nums": 1.0
            },
            {
              "nums": 2.0
            },
            {
              "nums": 3.0
            }
          ]
        }
    }

    @test subquery {
        out::print(select u.item from (select item from [1, 2, 3] as item) u);

        @expect output {
          [
            {
              "u.item": 1.0
            },
            {
              "u.item": 2.0
            },
            {
              "u.item": 3.0
            }
          ]
        }
    }
}
