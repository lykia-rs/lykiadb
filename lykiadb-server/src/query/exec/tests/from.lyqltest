@group from {

    @test simple_array {
        select item from [1, 2, 3] as item;

        @expect {
          [
            {
              "item": 1.0
            },
            {
              "item": 2.0
            },
            {
              "item": 3.0
            }
          ]
        }
    }

    @test single_element {
        select x from [42] as x;

        @expect {
          [
            {
              "x": 42.0
            }
          ]
        }
    }

    @test empty_array {
        select item from [] as item;

        @expect {
            []
        }
    }

    @test select_all_fields {
        select * from [1, 2, 3] as nums;

        @expect {
          [
            {
              "nums": 1.0
            },
            {
              "nums": 2.0
            },
            {
              "nums": 3.0
            }
          ]
        }
    }

    @test subquery {
        select u.item from (select item from [1, 2, 3] as item) u;

        @expect {
          [
            {
              "u.item": 1.0
            },
            {
              "u.item": 2.0
            },
            {
              "u.item": 3.0
            }
          ]
        }
    }
}
