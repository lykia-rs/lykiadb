@group aggregation {

    @test sum_all {
        select sum(item) as total from [1, 2, 3, 4, 5] as item;

        @expect {
            [
              {
                "total": 15.0
              }
            ]
        }
    }

    @test count_all {
        select count(item) as cnt from [1, 2, 3, 4, 5, 6] as item;

        @expect {
            [
              {
                "cnt": 6.0
              }
            ]
        }
    }

    @test avg_all {
        select avg(item) as mean from [10, 20, 30] as item;

        @expect {
            [
              {
                "mean": 20.0
              }
            ]
        }
    }

    @test group_by_bucket {
        var $data = arr::new(9);
        select col_0 as bucket, count(item) as cnt from $data as item group by mod(item, 3);

        @expect {
            [
              {
                "bucket": 0.0,
                "cnt": 3.0
              },
              {
                "bucket": 1.0,
                "cnt": 3.0
              },
              {
                "bucket": 2.0,
                "cnt": 3.0
              }
            ]
        }
    }

    @test having_clause {
        var $data = arr::new(10);
        select col_0 as bucket, sum(item) as total from $data as item group by mod(item, 2) having sum(item) > 20;

        // Two buckets exist:
        // [{bucket: 0, total: 20}, {bucket: 1, total: 25}]
        // But only the second one satisfies the HAVING condition, so only it is returned.

        @expect {
            [
              {
                "bucket": 1.0,
                "total": 25.0
              }
            ]
        }
    }
}
