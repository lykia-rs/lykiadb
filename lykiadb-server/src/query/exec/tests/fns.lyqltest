@group fns {

    @test fn_blocks {
        var $m = 2;
        var $s = 50;

        {
          var $m = 4;
          var $s = 100;
          function $buckets($size, $mod) {
              var $arr = arr::new($size);
              return select col_0 as m, sum(item) as a from $arr as item group by mod(item, $mod);
          };

          function $dbl($num) {
              return $num * 2;
          };

          {
              var $b = $buckets($s, $m);
              out::print(select $dbl(buckets.m) as m, buckets.a as a from $b as buckets);
          }
        }
        
        @expect output {
            [
              {
                "m": 0.0,
                "a": 1200.0
              },
              {
                "m": 2.0,
                "a": 1225.0
              },
              {
                "m": 4.0,
                "a": 1250.0
              },
              {
                "m": 6.0,
                "a": 1275.0
              }
            ]
        }
    }
}
