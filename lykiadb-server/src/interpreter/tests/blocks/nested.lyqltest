@group nested {

    @test nested_0 {
        var $a = "global a";
        var $b = "global b";
        var $c = "global c";
        {
            var $a = "outer a";
            var $b = "outer b";
            {
                var $a = "inner a";
                out::print($a);
                out::print($b);
                out::print($c);
            }
            out::print($a);
            out::print($b);
            out::print($c);
        }
        out::print($a);
        out::print($b);
        out::print($c);

        @expect output {
            "inner a"
            "outer b"
            "global c"
            "outer a"
            "outer b"
            "global c"
            "global a"
            "global b"
            "global c"
        }
    }

    @test nested_1 {
        function $fn_block() {
            var $a = "global";
            {
                var $a = "block";
                out::print($a);
            }
            out::print($a);
        };
        
        $fn_block();

        @expect output {
            "block"
            "global"
        }

        out::print($a);

        @expect error {
            Environment(Other { message: "Variable '$a' was not found" })
        }

        out::print($a);

        @expect output {
            "block"
            "global"
        }

        @expect error {
            Environment(Other { message: "Variable '$a' was not found" })
            Environment(Other { message: "Variable '$a' was not found" })
        }
    }
}
