@group anonymous {

    @test anonymous_fn_0 {
        var $pr = function $a() {
            out::print("hello");
        };
        
        $pr();
        $a();

        @expect output {
            hello
            hello
        }
    }

    @test anonymous_fn_1_iife {
        (function $a() {
            out::print("hello");
        })();
        
        $a();

        @expect output {
            hello
            hello
        }
    }

    @test anonymous_fn_2 {
        var $pr = function() {
            out::print("hello");
        };
        
        $pr();

        @expect output {
            hello
        }
    }

    @test anonymous_fn_3_iife {
        (function() {
            out::print("hello");
        })();

        @expect output {
            hello
        }
    }
}
