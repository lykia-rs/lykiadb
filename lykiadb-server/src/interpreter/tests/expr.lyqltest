@group expr {

    @test unary_evaluation {
        out::print(-2);
        out::print(-(-2));
        out::print(!3);
        out::print(!!3);
        out::print(!!!3);

        @expect output {
            -2
            2
            false
            true
            false
        }
    }

    @test binary_evaluation {
        out::print(5-(-2));
        out::print((5 + 2) * 4);
        out::print(5 + 2 * 4);
        out::print((13 + 4) * (7 + 3));
        out::print(-5-2);

        @expect output {
            7
            28
            13
            170
            -7
        }
    }

    @test string_coercion_in_comparison {
        out::print(100 < 11);
        out::print(100 < "11");
        out::print("100" < 11);
        out::print("100" < "11");

        @expect output {
            false
            false
            false
            true
        }
    }

    @test logical_evaluation {
        out::print(5 && 1);
        out::print(5 || 1);
        out::print(5 && 0);
        out::print(5 || 0);
        out::print(!(5 || 0));
        out::print(!(5 || 0) || 1);
        out::print(!(5 || 0) || (1 && 0));

        @expect output {
            true
            true
            false
            true
            false
            true
            false
        }
    }

    @test get_evaluation {
        var $obj = {
            name: "John",
            age: 30,
            address: {
                city: "New York",
                zip: 10001
            }
        };
        
        out::print($obj.name);
        out::print($obj.age);
        out::print($obj.address.city);
        out::print($obj.address.zip);

        @expect output {
            John
            30
            New York
            10001
        }
    }

    @test get_errors {
        var $obj = {
            name: "John"
        };
        
        out::print($obj.age);

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 45, end: 53, line: 4, line_end: 4 }, property: "age" })
        }

        out::print($obj.address.city);

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 45, end: 53, line: 4, line_end: 4 }, property: "age" })
            Interpret(PropertyNotFound { span: Span { start: 11, end: 23, line: 0, line_end: 0 }, property: "address" })
        }

        out::print(undefined.prop);

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 45, end: 53, line: 4, line_end: 4 }, property: "age" })
            Interpret(PropertyNotFound { span: Span { start: 11, end: 23, line: 0, line_end: 0 }, property: "address" })
            Interpret(InvalidPropertyAccess { span: Span { start: 11, end: 25, line: 0, line_end: 0 }, value_str: "undefined" })
        }

        out::print(5.prop);

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 45, end: 53, line: 4, line_end: 4 }, property: "age" })
            Interpret(PropertyNotFound { span: Span { start: 11, end: 23, line: 0, line_end: 0 }, property: "address" })
            Interpret(InvalidPropertyAccess { span: Span { start: 11, end: 25, line: 0, line_end: 0 }, value_str: "undefined" })
            Interpret(InvalidPropertyAccess { span: Span { start: 11, end: 17, line: 0, line_end: 0 }, value_str: "5" })
        }

        out::print("string".length);

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 45, end: 53, line: 4, line_end: 4 }, property: "age" })
            Interpret(PropertyNotFound { span: Span { start: 11, end: 23, line: 0, line_end: 0 }, property: "address" })
            Interpret(InvalidPropertyAccess { span: Span { start: 11, end: 25, line: 0, line_end: 0 }, value_str: "undefined" })
            Interpret(InvalidPropertyAccess { span: Span { start: 11, end: 17, line: 0, line_end: 0 }, value_str: "5" })
            Interpret(InvalidPropertyAccess { span: Span { start: 11, end: 26, line: 0, line_end: 0 }, value_str: "string" })
        }
    }

    @test set_evaluation {
        var $obj = {
            name: "John",
            age: 30,
            address: {
                city: "New York",
                zip: 10001
            }
        };
        
        $obj.name = "Jane";
        out::print($obj.name);
        
        $obj.age = 31;
        out::print($obj.age);
        
        $obj.address.city = "Boston";
        out::print($obj.address.city);
        
        $obj.newProp = "test";
        out::print($obj.newProp);

        @expect output {
            Jane
            31
            Boston
            test
        }
    }

    @test set_errors {
        var $obj = {
            name: "John"
        };
        
        $obj.address.city = "Boston";

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 34, end: 46, line: 4, line_end: 4 }, property: "address" })
        }

        undefined.prop = "test";

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 34, end: 46, line: 4, line_end: 4 }, property: "address" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 23, line: 0, line_end: 0 }, value_str: "undefined" })
        }

        5.prop = "test";

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 34, end: 46, line: 4, line_end: 4 }, property: "address" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 23, line: 0, line_end: 0 }, value_str: "undefined" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 15, line: 0, line_end: 0 }, value_str: "5" })
        }

        "string".prop = "test";

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 34, end: 46, line: 4, line_end: 4 }, property: "address" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 23, line: 0, line_end: 0 }, value_str: "undefined" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 15, line: 0, line_end: 0 }, value_str: "5" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 22, line: 0, line_end: 0 }, value_str: "string" })
        }

        undefined.prop = "test";

        @expect error {
            Interpret(PropertyNotFound { span: Span { start: 34, end: 46, line: 4, line_end: 4 }, property: "address" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 23, line: 0, line_end: 0 }, value_str: "undefined" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 15, line: 0, line_end: 0 }, value_str: "5" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 22, line: 0, line_end: 0 }, value_str: "string" })
            Interpret(InvalidPropertyAccess { span: Span { start: 0, end: 23, line: 0, line_end: 0 }, value_str: "undefined" })
        }
    }

    @test numeric_between {
        var $x = 5;
        out::print($x between 1 and 10);
        out::print($x between 5 and 10);
        out::print($x between 1 and 5);
        out::print($x between 6 and 10);
        out::print($x between 0 and 4);
        out::print($x not between 1 and 10);
        out::print($x not between 5 and 10);
        out::print($x not between 1 and 5);
        out::print($x not between 6 and 10);
        out::print($x not between 0 and 4);
        
        // String coercion
        out::print($x between "1" and 10);
        out::print($x between 5 and "10");
        out::print($x between "1" and "5");
        out::print($x between "0" and 4);
        out::print($x not between "1" and 10);
        out::print($x not between 5 and "10");
        out::print($x not between "1" and "5");
        out::print($x not between "0" and 4);
        out::print(100 between 1 and 11); // Numerical ordering
        out::print(100 between "1" and "11"); // Numerical ordering

        @expect output {
            true
            true
            true
            false
            false
            false
            false
            false
            true
            true
            true
            true
            true
            false
            false
            false
            false
            true
            false
            false
        }
    }

    @test string_between {
        out::print("mice" between "alligator" and "zebra");
        out::print("alligator" between "mice" and "zebra");
        out::print("zebra" between "alligator" and "mice");
        out::print("mice" between "mice" and "mice");
        out::print("100" between "1" and "11"); // Lexicographical ordering

        @expect output {
            true
            false
            false
            true
            true
        }

        out::print("100" between "1" and 11); // Coercion to string, lexicographical ordering

        @expect output {
            true
            false
            false
            true
            true
            true
        }
    }

    @test obj_assignment {
        var $object = {};
        $object.test = 1;
        
        out::print($object.test == 1);

        @expect output {
            true
        }
    }

    @test obj_assignment {
        var $object = {};
        $object.level_one = {};
        $object.level_one.level_two = {};
        $object.level_one.level_two.level_three = {};
        
        $object.level_one.title = "1";
        $object.level_one.level_two.title = "2";
        $object.level_one.level_two.level_three.title = "3";
        
        out::print($object.level_one.title);
        out::print($object.level_one.level_two.title);
        out::print($object.level_one.level_two.level_three.title);

        @expect output {
            1
            2
            3
        }
    }
}
