@set(run = "interpreter")
@group ifs {

    @test simple {
        var $a = 30;
        
        if ($a > 50) {
            out::print("> 50");
        }
        else if ($a > 20) {
            out::print("50 > $a > 20");
        }
        else {
            out::print("< 20");
        }

        @expect output {
            50 > $a > 20
        }
    }
}
