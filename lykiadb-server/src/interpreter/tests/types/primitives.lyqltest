@group primitives {

    @test numerical {
        out::print(dtype::of_(1) == dtype::double);
        out::print(dtype::of_(1.12) == dtype::double);
        out::print(dtype::of_(1) == dtype::str);
        out::print(dtype::of_(1));
        out::print(dtype::of_(1.12));

        @expect output {
            true
            true
            false
            "Double"
            "Double"
        }
    }

    @test string {
        out::print(dtype::of_("1") == dtype::str);
        out::print(dtype::of_("1") == dtype::double);
        out::print(dtype::of_("1"));

        @expect output {
            true
            false
            "Str"
        }
    }

    @test boolean {
        out::print(dtype::of_(true) == dtype::bool);
        out::print(dtype::of_(false) == dtype::bool);
        out::print(dtype::of_(true) == dtype::str);
        out::print(dtype::of_(true));
        out::print(dtype::of_(false));

        @expect output {
            true
            true
            false
            "Bool"
            "Bool"
        }
    }

    @test array {
        out::print(dtype::of_([1, 2, 3]) == dtype::array(dtype::double));
        out::print(dtype::of_([1, 2, 3]) == dtype::array(dtype::str));
        out::print(dtype::of_([1, 2, 3]));

        @expect output {
            true
            false
            {
              "Array": "Double"
            }
        }
    }

    @test object {
        out::print(dtype::of_({a: 1, b: 2}) == dtype::object({a: dtype::double, b: dtype::double}));
        out::print(dtype::of_({a: [1, 2, 3] }) == dtype::object({a: dtype::array(dtype::double)}));
        out::print(dtype::of_({a: [1, 2, 3] }));
        out::print(dtype::of_({a: 1, b: 2}));

        @expect output {
            true
            true
            {
              "Object": {
                "a": {
                  "Array": "Double"
                }
              }
            }
            {
              "Object": {
                "b": "Double",
                "a": "Double"
              }
            }
        }
    }

    @test callable {
        out::print(dtype::of_(out::print) == dtype::str);
        out::print(dtype::of_(out::print));

        @expect output {
            false
            {
              "Callable": [
                "Unknown",
                "Unknown"
              ]
            }
        }
    }

    @test datatype {
        out::print(dtype::of_(dtype::double) == dtype::dtype);
        out::print(dtype::of_(dtype::double) == dtype::str);
        out::print(dtype::of_(dtype::double));

        @expect output {
            true
            false
            "Datatype"
        }
    }

    @test none {
        out::print(dtype::of_(undefined) == dtype::none);
        out::print(dtype::of_(undefined) == dtype::str);
        out::print(dtype::of_(undefined));

        @expect output {
            true
            false
            "None"
        }
    }
}
