@group programs {

    @test multiple_programs {
        function $resolved_first() {
            var $a = "global";
            {
                function $show_a() {
                    out::print($a);
                };
            
                $show_a();
                var $a = "block";
                $show_a();
            }
        };
        $resolved_first();

        @expect output {
            global
            global
        }

        $resolved_first();

        @expect output {
            global
            global
            global
            global
        }
    }
}
